# App
APP_NAME="EHS Inspection API"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=change-me-to-a-random-64-char-string

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-frontend.example.com,https://admin.example.com

# Rate limiting (slowapi)
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_HEAVY=20/minute

# Database (PostgreSQL + pgvector) — optional, enables hybrid DB lookup for Req1
DATABASE_URL=postgresql+asyncpg://ehs_user:password@localhost:5432/ehs_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Embedding model — used for pgvector similarity search (Req1 hybrid lookup)
EMBED_MODEL_NAME=all-MiniLM-L6-v2
HYBRID_VECTOR_THRESHOLD=0.82
HYBRID_TRGM_THRESHOLD=0.45

# Groq — required for Req1 LLM fallback, Req2 RA generation, Req4 quiz, Req5 hazard analysis
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Quiz
QUIZ_NUM_QUESTIONS=5
